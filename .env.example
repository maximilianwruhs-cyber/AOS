# AOS Environment Variables
# Copy this to .env and customize

# LLM Backend URL (set by remote_hosts.json, override here if needed)
# OLLAMA_URL=http://localhost:1234/v1

# Default model for benchmarks
# AOS_MODEL=qwen2.5-coder-1.5b-instruct

# API Authentication (leave empty to disable auth in dev mode)
# AOS_API_KEY=your-secret-key-here

# Arena defaults
# AOS_TOKENS_PER_ROUND=2048
# AOS_INITIAL_BALANCE=100.0
