{
  "mcpServers": {
    "google-workspace": {
      "command": "npx",
      "args": [
        "-y",
        "google-workspace-mcp",
        "serve"
      ]
    },
    "notebooklm": {
      "command": "uvx",
      "args": [
        "--from",
        "notebooklm-mcp-cli",
        "notebooklm-mcp"
      ]
    },
    "lm-studio": {
      "command": "uv",
      "args": [
        "run",
        "--with",
        "fastmcp",
        "--with",
        "httpx",
        "/home/{{ real_user }}/.gemini/antigravity/lm_studio_mcp.py"
      ]
    }
  }
}
